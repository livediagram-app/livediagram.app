{
  "name": "@livediagram/router",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --env local --port 3000 --inspector-port 9231",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .wrangler node_modules .turbo"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@livediagram/eslint-config": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.40.0"
  }
}
