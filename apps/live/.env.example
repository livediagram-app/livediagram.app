# Live app environment variables.
#
# Anything prefixed `NEXT_PUBLIC_` is baked into the static export at
# build time and shipped to the browser. Everything else is build-only.
# Per spec 06 the repo is public, so never put secrets in NEXT_PUBLIC_
# variables.

# Where the live app calls the API. In production (Cloudflare) the
# router stitches the API onto the same hostname under `/api/*`, so
# leaving this unset is correct.
#
# For local development you'll want to override this:
#
# - Point at the deployed API (uses prod D1!):
#     NEXT_PUBLIC_API_BASE=https://www.livediagram.app/api
#
# - Point at a local `wrangler dev` of @livediagram/api:
#     NEXT_PUBLIC_API_BASE=http://localhost:8787/api
#
# Copy this file to `.env.local` and edit. `.env.local` is gitignored.
NEXT_PUBLIC_API_BASE=

# Clerk publishable key for the live app's auth provider. Required —
# without it the app renders a "Clerk not configured" fallback card
# instead of the editor. Get this from the Clerk dashboard
# (https://dashboard.clerk.com → API Keys → Publishable key). Format:
# `pk_test_*` for dev tenants, `pk_live_*` for prod. Safe to commit
# to source / ship in client bundles (per Clerk docs + spec/06).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
